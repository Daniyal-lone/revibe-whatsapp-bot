NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgres://revibe:revibe_password@localhost:5432/revibe_salon
JWT_SECRET=change-this-long-random-secret

# Simple role PINs for first deployment. Replace before going live.
STAFF_PIN=1111
OWNER_PIN=2222
DEVELOPER_PIN=3333
ENABLE_INLINE_AUTOMATION=true

# WhatsApp Cloud API. Leave disabled until Meta/Gupshup/Twilio details are ready.
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v23.0
WHATSAPP_RECEIPT_TEMPLATE_NAME=revibe_receipt_image
WHATSAPP_MARKETING_TEMPLATE_NAME=revibe_return_reminder

# Developer alert webhook/email service, optional for MVP.
DEVELOPER_ALERT_WEBHOOK_URL=
